# Appearance
theme = Catppuccin Mocha
font-family = "JetBrainsMono Nerd Font"
font-size = 11
font-feature = -calt, -liga

# Window Styling
window-decoration = false
window-padding-x = 12
window-padding-y = 6

# Transparency & Frost Effect
background-opacity = 0.85
background-blur = true

# Cursor
cursor-style = block
cursor-style-blink = true

# Copy on select
copy-on-select = true
