{
  "agents": {
    "prometheus": {
      "model": "openrouter/anthropic/claude-opus-4.7"
    },
    "metis": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "fallback_models": [
        {
          "model": "openrouter/anthropic/claude-sonnet-4-6"
        }
      ]
    },
    "momus": {
      "model": "openrouter/anthropic/claude-opus-4.7",
      "fallback_models": [
        {
          "model": "openrouter/anthropic/claude-sonnet-4-6"
        }
      ]
    },
    "sisyphus": {
      "model": "openrouter/z-ai/glm-5",
      "fallback_models": [
        {
          "model": "openrouter/moonshotai/kimi-k2.5"
        }
      ],
      "config": {
        "dcp_enabled": true,
        "max_context_tokens": 40000
      }
    },
    "atlas": {
      "model": "openrouter/z-ai/glm-5",
      "fallback_models": [
        {
          "model": "openrouter/moonshotai/kimi-k2.5"
        }
      ],
      "config": {
        "dcp_enabled": true
      }
    },
    "hephaestus": {
      "model": "openrouter/z-ai/glm-5",
      "fallback_models": [
        {
          "model": "openrouter/moonshotai/kimi-k2.6"
        }
      ]
    },
    "oracle": {
      "model": "openrouter/deepseek/deepseek-v3.2",
      "fallback_models": [
        {
          "model": "openrouter/openai/gpt-5.4"
        }
      ]
    },
    "multimodal-looker": {
      "model": "openrouter/moonshotai/kimi-k2.6",
      "fallback_models": [
        {
          "model": "openrouter/openai/gpt-5.4"
        }
      ]
    },
    "sisyphus-junior": {
      "model": "openrouter/qwen/qwen2.5-coder-7b-instruct",
      "fallback_models": [
        {
          "model": "openrouter/qwen/qwen2.5-coder-7b-instruct"
        }
      ]
    },
    "explore": {
      "model": "openrouter/minimax/minimax-m2.7",
      "config": {
        "use_dcp_index": true,
        "priority": "speed",
        "system_prompt_suffix": "Use dcp_query_symbols to map files before reading full content."
      }
    },
    "librarian": {
      "model": "openrouter/minimax/minimax-m2.7",
      "config": {
        "dcp_enabled": true
      }
    }
  }
}
